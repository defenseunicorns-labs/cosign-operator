{
  "name": "image-signature-policy",
  "version": "0.0.1",
  "description": "Pepr policy that enforces cosign image signature verification",
  "scripts": {
    "dev": "npx pepr dev",
    "build": "npx pepr build",
    "format": "npx prettier --write **/*.ts",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "pepr": "1.2.1"
  },
  "pepr": {
    "name": "Image Signature Policy",
    "uuid": "image-signature-policy",
    "onError": "reject",
    "logLevel": "info",
    "alwaysIgnore": {
      "namespaces": [
        "pepr-system",
        "kube-sytem",
        "istio-system",
        "zarf"
      ]
    }
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  }
}
