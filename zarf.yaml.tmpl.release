kind: ZarfPackageConfig
metadata:
  name: pepr-image-signature-policy
  description: 'Pepr Module: Pepr policy that enforces cosign image signature verification'
  url: https://github.com/defenseunicorns/pepr
  version: ${VERSION}
components:
  - name: cosign-hook
    required: true
    images:
      - registry.defenseunicorns.com/navy-canes/controller:v1.2.2
    charts:
      - name: cosign-hook
        namespace: pepr-system
        version: ${VERSION}
        localPath: chart
